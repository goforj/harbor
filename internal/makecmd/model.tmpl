func (r *{{.ModelName}}Repo) GetWhere(where map[string]any) ([]{{.ModelName}}, error) {
	conn, err := r.connection()
	if err != nil {
		return nil, err
	}
	var models []{{.ModelName}}
	if err := conn.Where(where).Find(&models).Error; err != nil {
		return nil, err
	}
	return models, nil
}

