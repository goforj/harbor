// {{.ModelName}}Repo provides persistence helpers for {{.ModelName}}.
type {{.ModelName}}Repo struct {
	db  *database.Connections
	ctx context.Context
}

// New{{.ModelName}}Repo creates a new {{.ModelName}} repository.
func New{{.ModelName}}Repo(db *database.Connections) *{{.ModelName}}Repo {
	return &{{.ModelName}}Repo{db: db}
}

// WithContext returns a shallow repo clone bound to one execution context.
func (r *{{.ModelName}}Repo) WithContext(ctx context.Context) *{{.ModelName}}Repo {
	if r == nil {
		return nil
	}
	clone := *r
	clone.ctx = ctx
	return &clone
}

// Builder returns a query builder for {{.ModelName}}.
// Treat this as an escape hatch for quick manual querying; prefer repository methods.
func (r *{{.ModelName}}Repo) Builder() (*gorm.DB, error) {
	return r.connection()
}

// connection resolves the default database connection for repository actions.
func (r *{{.ModelName}}Repo) connection() (*gorm.DB, error) {
	conn, err := r.db.Default()
	if err != nil {
		return nil, err
	}
	if r.ctx != nil {
		conn = conn.WithContext(r.ctx)
	}
	return conn, nil
}

// ByID fetches a {{.ModelName}} by primary key.
func (r *{{.ModelName}}Repo) ByID(id any) (*{{.ModelName}}, error) {
	conn, err := r.connection()
	if err != nil {
		return nil, err
	}
	var model {{.ModelName}}
	if idAsString, ok := id.(string); ok {
		if err := conn.Where("id = ?", idAsString).First(&model).Error; err != nil {
			return nil, err
		}
	} else if err := conn.First(&model, id).Error; err != nil {
		return nil, err
	}
	return &model, nil
}

